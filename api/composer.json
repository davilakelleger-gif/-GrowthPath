{
    "name": "growthpath/api",
    "description": "GrowthPath API - Habit tracking application backend",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0",
        "laravel/sanctum": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Migrations\\": "database/migrations/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "php artisan migrate",
            "php artisan storage:link"
        ]
    }
}
